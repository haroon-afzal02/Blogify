<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head.ejs') %>
        <title>homepage</title>
</head>

<body>

    <%- include('./partials/nav.ejs') %>

        <!-- Hero Section -->
        <section class="bg-dark text-white text-center py-5">
            <div class="container">

                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                    ✍️ Welcome to Blogify
                </span>

                <h1 class="display-5 fw-bold mt-4">
                    Discover stories,
                    <span class="text-warning">ideas</span>,
                    and inspiration.
                </h1>

                <p class="lead text-white-50 mt-3 mb-0">
                    Read blogs from talented writers or share your own thoughts with the world.
                </p>

            </div>
        </section>

        <div class="container py-5">

            <div class="row g-4">

                <% if (!locals.blogs || blogs.length===0) { %>
                    <div class="col-12">
                        <div class="text-center p-5 bg-light rounded-3 border">
                            <h2>No Blogs Yet</h2>
                            <p class="text-muted mb-0">
                                Be the first one to publish an amazing story.
                            </p>
                        </div>
                    </div>
                    <% } %>

                        <% blogs.forEach(blog=> { %>

                            <div class="col-lg-4 col-md-6 d-flex">

                                <div class="card h-100 shadow-sm">

                                    <img src="<%= blog.coverImage %>" class="card-img-top object-fit-cover"
                                        alt="<%= blog.title %>" style="height: 200px;">

                                    <div class="card-body d-flex flex-column">

                                        <span class="badge bg-success-subtle text-success-emphasis mb-2 align-self-start">
                                            Blog
                                        </span>

                                        <h5 class="card-title fw-bold flex-grow-1">
                                            <%= blog.title %>
                                        </h5>

                                        <a href="/blog/<%= blog._id %>" class="btn btn-outline-success btn-sm mt-2">
                                            Read Article →
                                        </a>

                                    </div>

                                </div>

                            </div>

                            <% }) %>

            </div>

        </div>

        <%- include('./partials/scripts.ejs') %>

</body>

</html>
