<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">

    <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" href="/">
      <i class="bi bi-journal-richtext text-warning fs-4"></i>
      <span>Blogify</span>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavDropdown">

      <ul class="navbar-nav mx-auto">

        <li class="nav-item">
          <a class="nav-link active" href="/">Home</a>
        </li>

        <% if (locals.user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/blog/add-new">Write Story</a>
          </li>
          <% } %>

      </ul>

      <div class="d-flex align-items-center gap-2">

        <% if(locals.user){ %>

          <div class="dropdown">
            <button class="btn btn-outline-light d-flex align-items-center gap-2" data-bs-toggle="dropdown">
              <span
                class="rounded-circle bg-success d-flex align-items-center justify-content-center text-white fw-bold"
                style="width: 32px; height: 32px;">
                <%= locals.user.fullName.charAt(0).toUpperCase() %>
              </span>
              <span>
                <%= locals.user.fullName %>
              </span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
              <li>
                <a class="dropdown-item text-danger" href="/user/logout">Logout</a>
              </li>
            </ul>
          </div>

          <% } else { %>

            <a href="/user/signin" class="btn btn-outline-light">Sign In</a>
            <a href="/user/signup" class="btn btn-warning fw-semibold">Get Started</a>

            <% } %>

      </div>

    </div>

  </div>
</nav>

<% if (locals.error) { %>

  <div class="container mt-3">
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-0" role="alert">
      <i class="bi bi-exclamation-triangle-fill"></i>
      <div><strong>Oops!</strong>
        <%= locals.error %>
      </div>
    </div>
  </div>

  <% } %>